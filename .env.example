# ── Supabase ────────────────────────────────────────────────────────────
# Récupère ces valeurs dans ton projet Supabase : Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé "service_role" (SECRET — jamais côté client). Utilisée uniquement
# côté serveur pour enregistrer les candidatures et lire le dashboard.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Compteur public de la Cohorte 01 ────────────────────────────────────
# Nombre affiché = base + candidatures réelles enregistrées.
NEXT_PUBLIC_COHORTE_BASE=0
NEXT_PUBLIC_COHORTE_OBJECTIF=500

# ── Divers ──────────────────────────────────────────────────────────────
# URL publique du site (pour l'OpenGraph / sitemap). Ex : https://ambassadeurs.199.cd
NEXT_PUBLIC_SITE_URL=https://ambassadeurs.199.cd
